# 复制为 .env 后填写。勿将含真实密钥的 .env 提交到公开仓库。

# —— 智能问答（DeepSeek，OpenAI 兼容接口）——
# 在 https://platform.deepseek.com 创建 API Key（一般以 sk- 开头）
# 注意：与下方高德地图的 key / 安全密钥不是同一套，不能混用
VITE_AI_API_URL=https://api.deepseek.com/chat/completions
VITE_AI_MODEL=deepseek-chat
VITE_AI_API_KEY=

# —— 小游戏一「徽州古建修复」（Django iframe）——
# 开发时一般可不填：默认请求 http://127.0.0.1:8000，需先在仓库 game/fuzhou-ancient-house-restorer-main/Game 执行 python manage.py runserver 8000
# VITE_HUIZHOU_GAME_URL=http://127.0.0.1:8000
# 设为 false 可关闭嵌入
# VITE_HUIZHOU_GAME_URL=false

# —— 高德地图（仅地图用）——
VITE_AMAP_KEY=
VITE_AMAP_SECURITY_JS_CODE=
